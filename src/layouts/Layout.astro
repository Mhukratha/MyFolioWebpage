<script is:inline>
		const skillsData = {
  technical: [
    { name: "Unity (Intermediate-Advanced)", img: "/img/unity.png" },
    { name: "Blender (Intermediate-Advanced)", img: "/img/blender.png" },
    { name: "Unreal Engine (Intermediate)", img: "/img/unreal.png" },
    { name: "C# (Intermediate)", img: "/img/csharp.png" },
    { name: "HTML5/CSS (Intermediate)", img: "/img/html5.png" },
    { name: "GitHub (Intermediate)", img: "/img/github.png" },
    { name: "Maya (Intermediate)", img: "/img/maya.png" },
    { name: "Figma (Intermediate)", img: "/img/figma.png" },
    { name: "-------", img: "/img/unity.png" }
  ],
  professional: [
    { name: "Project Management", img: "/img/dot.png" },
    { name: "Game Design", img: "/img/dot.png" },
    { name: "Problem Solving", img: "/img/dot.png" },
    { name: "Team Collaboration", img: "/img/dot.png" },
    { name: "Debugging", img: "/img/dot.png" },
    { name: "Fast Learner", img: "/img/dot.png" },
  ],
  additional: [
    { name: "Video Editing", img: "/img/dot.png" },
    { name: "Photography", img: "/img/dot.png" },
    { name: "Stock Trading", img: "/img/dot.png" },
  ]
};

const skillButtons = document.querySelectorAll('.tab-btn');
const gridContainer = document.getElementById('skills-grid-container');

function renderSkills(category) {
  const skills = skillsData[category] || [];
  gridContainer.innerHTML = skills.map(skill => `
    <div class="skill-card">
      <img src="${skill.img}" alt="${skill.name}">
      <span>${skill.name}</span>
    </div>
  `).join('');
}

renderSkills('technical');

skillButtons.forEach(btn => {
  btn.addEventListener('click', () => {
    skillButtons.forEach(b => {
      b.classList.remove('active');
      b.classList.add('inactive');
    });
    btn.classList.add('active');
    btn.classList.remove('inactive');

    const category = btn.getAttribute('data-category');
    renderSkills(category);
  });
});


  const projectData = {
    project1: {
      story: "In a world where human civilization has collapsed due to a zombie outbreak, a 19-year-old girl who grew up in a small shelter headed by her uncle. One day, her shelter was robbed and killed by people from other groups to steal supplies. She was the only survivor and found clues of a government shelter behind the walls, a shelter where survivors still lived as before the zombie outbreak. She wanted to go there, so she had to travel across dangerous cities to get to the shelter behind the high walls. Along the way, she encountered various types of zombies, as well as groups of surviving humans.",
      tasks: [
        "Planned the entire development roadmap, focusing on core gameplay and story progression first.",
        "Organized and tracked every task—from coding the character system to creating cutscenes—to meet deadlines.",
        "Create the game system that is related to the player, the character code, the basic system, and the object interaction system.",
        "Make animations, cutscenes, and various objects to create scenes in the game."
      ]
    },
    project2: {
      story: "Aenalia is the limitless and infinite universe formed by a network of unique interconnected virtual worlds known as theMetaverse Spaces. This universe contributes by Creators/Artists through Unreal Engine, a tool that loves by creators around the world. And comes with services that will allow you, me, and others to own the spaces as NFTs (Create and Own any dreamy place you dream), including services that will keep us all connected, express ourselves, create activities, and other possibilities through those spaces. Home and Community space on Metaverse.",
      tasks: [
        "Make a map of this project with the environment inside, including animation within the work.",
        "Create 3D model works for the work of an artist and arrange the composition in the scene for beauty and realism.",
      ]
    },
    project3: {
      story: "In this game, players can transform into various toys to explore a vast and exciting world of living toys. Players can use the unique abilities of each toy to overcome various obstacles on their adventure.",
      tasks: [
        "Create 3D model assets for the scence.",
        "Disign and create 3D Model character in game.",
      ]
    }
  };

  const items = document.querySelectorAll('.project-item');
  const storyText = document.querySelector('.project-story');
  const taskList = document.querySelector('.responsibilities ul');

  items.forEach(item => {
    item.addEventListener('click', () => {
      items.forEach(i => i.classList.remove('active'));
      item.classList.add('active');

      const id = item.getAttribute('data-project');
      const data = projectData[id];

      storyText.innerText = data.story;
      taskList.innerHTML = data.tasks.map(task => `<li>${task}</li>`).join('');
    });
  });
</script>